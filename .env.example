# Required for Fashion -> Ostock backend integration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required for server-side catalog + branch_stock (use the service_role key from the API page)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional branch scope (used by stock-aware catalog queries)
FASHION_DEFAULT_BRANCH_ID=your-branch-id

# Feature flags
# Set to false to disable backend integration temporarily
USE_OSTOCK_BACKEND=true

# MSW toggles (off by default in runtime now)
ENABLE_MSW=false
NEXT_PUBLIC_ENABLE_MSW=false
